{
  "info": {
    "_postman_id": "4f7150df-0ecf-426d-b9f0-7d72bf85a46f",
    "name": "BrainAPI Trivia",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for BrainAPI OpenTDB-style trivia backend"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "email", "value": "admin@example.com" },
    { "key": "password", "value": "Admin@123" },
    { "key": "username", "value": "admin" },
    { "key": "jwtToken", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "questionId", "value": "" },
    { "key": "sessionToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('jwtToken', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories?page=1&limit=10"
          }
        },
        {
          "name": "Create Category (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json._id) { pm.collectionVariables.set('categoryId', json._id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Technology\",\n  \"description\": \"Tech trivia questions\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Technology Updated\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "Get Questions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/questions?amount=10&page=1&limit=10&difficulty=easy&type=multiple"
          }
        },
        {
          "name": "Create Question (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json._id) { pm.collectionVariables.set('questionId', json._id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"{{categoryId}}\",\n  \"type\": \"multiple\",\n  \"difficulty\": \"easy\",\n  \"question\": \"What color is the sky on a clear day?\",\n  \"correct_answer\": \"Blue\",\n  \"incorrect_answers\": [\"Green\", \"Red\", \"Yellow\"]\n}"
            },
            "url": "{{baseUrl}}/questions"
          }
        },
        {
          "name": "Update Question (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"difficulty\": \"medium\",\n  \"question\": \"What color is a clear daytime sky?\",\n  \"correct_answer\": \"Blue\",\n  \"incorrect_answers\": [\"Purple\", \"Orange\", \"Pink\"]\n}"
            },
            "url": "{{baseUrl}}/questions/{{questionId}}"
          }
        },
        {
          "name": "Delete Question (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": "{{baseUrl}}/questions/{{questionId}}"
          }
        },
        {
          "name": "Import Questions JSON (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questions\": [\n    {\n      \"categoryName\": \"Sports\",\n      \"type\": \"boolean\",\n      \"difficulty\": \"easy\",\n      \"question\": \"Football is played with a round ball.\",\n      \"correct_answer\": \"False\",\n      \"incorrect_answers\": [\"True\"]\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/questions/import"
          }
        }
      ]
    },
    {
      "name": "Token",
      "item": [
        {
          "name": "Generate Session Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('sessionToken', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": "{{baseUrl}}/token"
          }
        },
        {
          "name": "Delete Session Token",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": "{{baseUrl}}/token/{{sessionToken}}"
          }
        }
      ]
    }
  ]
}
